# Raindrop MCP Server - Cloudflare Worker production secrets.
# Set these with `bunx wrangler secret put <NAME>`.

# OAuth configuration (required for multi-user OAuth).
OAUTH_CLIENT_ID=your_oauth_client_id_here
OAUTH_CLIENT_SECRET=your_oauth_client_secret_here
OAUTH_REDIRECT_URI=https://your-worker-domain.example.com/auth/callback
OAUTH_ALLOWED_REDIRECT_URIS=https://your-worker-domain.example.com/dashboard,/dashboard

# Token encryption (required for OAuth sessions).
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=your_64_character_hex_key_here

# JWT signing key (required for OAuth token issuance).
# Generate with: openssl rand -base64 32
JWT_SIGNING_KEY=your_base64_jwt_signing_key

# Optional direct token mode (single-user/private deployments only).
# RAINDROP_ACCESS_TOKEN=your_raindrop_token_here
# ALLOW_ENV_TOKEN_AUTH=true

# Optional endpoint protection.
# API_KEY=your_api_key_for_endpoint_protection
