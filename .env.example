# Local development variables for Wrangler.
# For local Worker dev, copy the needed values to `.dev.vars`.

# Direct token mode for local smoke testing.
# Get a token from https://app.raindrop.io/settings/integrations
RAINDROP_ACCESS_TOKEN=your_access_token_here
ALLOW_ENV_TOKEN_AUTH=true

# OAuth configuration for local multi-user testing.
# Get OAuth credentials from https://raindrop.io/dev/apps
OAUTH_CLIENT_ID=your_oauth_client_id
OAUTH_CLIENT_SECRET=your_oauth_client_secret
OAUTH_REDIRECT_URI=http://localhost:8787/auth/callback
OAUTH_ALLOWED_REDIRECT_URIS=http://localhost:8080/callback,/dashboard

# Security.
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=your_64_char_hex_encryption_key

# JWT configuration.
# Generate JWT_SIGNING_KEY with: openssl rand -base64 32
JWT_SIGNING_KEY=your_base64_jwt_signing_key
JWT_ISSUER=http://localhost:8787
JWT_ACCESS_TOKEN_EXPIRY=3600
JWT_REFRESH_TOKEN_EXPIRY=2592000

# Optional endpoint protection.
API_KEY=optional_server_api_key
